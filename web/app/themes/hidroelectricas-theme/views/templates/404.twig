{% extends "/layouts/base.twig" %}

{% block content %}
	<div class="wide-container flex flex-col items-center justify-center py-24 text-center">
		<p class="text-8xl font-bold text-[#92b75e]">404</p>
		<h1 class="mt-4 text-2xl font-semibold text-[#232323]">Página no encontrada</h1>
		<p class="mt-3 max-w-md text-[#555]">
			Lo sentimos, la página que buscás no existe o fue movida.
		</p>
		<a href="{{ site.url }}" class="mt-8 inline-block bg-[#376e72] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#92b75e]">
			Volver al inicio
		</a>
	</div>
{% endblock %}
