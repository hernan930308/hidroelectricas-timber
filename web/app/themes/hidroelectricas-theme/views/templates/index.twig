{% extends "/layouts/base.twig" %}

{% block content %}
	{% for post in posts %}
		{% include ['partial/tease-'~post.post_type~'.twig', 'partial/tease.twig'] %}
	{% endfor %}
	
	{% include 'partial/pagination.twig' with { pagination: posts.pagination({show_all: false, mid_size: 3, end_size: 2}) } %}
{% endblock %}
