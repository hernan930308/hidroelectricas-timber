<section class="w-full py-10">

	<div class="mx-auto max-w-[min(1280px,calc(100vw-2rem))]">

		<h2 class="text-2xl font-bold mb-8 text-center">Compra por categoría</h2>

        {{ fields.categoria }}

		{% if product_categories %}
			<ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0 m-0">
				{% for category in product_categories %}
					<li>
						<a href="{{ fn('get_term_link', category.term_id) }}"
						   class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white shadow hover:shadow-md transition-shadow duration-200 no-underline group">

							{% set thumbnail_id = fn('get_term_meta', category.term_id, 'thumbnail_id', true) %}

							{% if thumbnail_id %}
								{% set image = fn('wp_get_attachment_image_src', thumbnail_id, 'medium_large') %}
								<img src="{{ image[0] }}"
								     alt="{{ category.name }}"
								     class="w-full aspect-4/5 object-cover rounded-xl">
							{% else %}
								<div class="w-full aspect-4/5 rounded-xl bg-gray-100 flex items-center justify-center">
									<svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
									</svg>
								</div>
							{% endif %}

							<h3 class="text-sm font-semibold text-center text-gray-800 group-hover:text-primary transition-colors duration-200 m-0">
								{{ category.name }}
							</h3>

							{% if category.description %}
								<p class="text-xs text-gray-500 text-center m-0 line-clamp-2">
									{{ category.description }}
								</p>
							{% endif %}

						</a>
					</li>
				{% endfor %}
			</ul>
		{% else %}
			<p class="text-center text-gray-400">No hay categorías disponibles.</p>
		{% endif %}

	</div>

</section>
